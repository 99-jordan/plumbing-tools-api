# Local dev: copy to .env — production: set in Vercel → Project → Settings → Environment Variables

PORT=3000
# Tool header name: x-elevenlabs-secret-plumbingpro (same value as below)
# Preferred; legacy X_ELEVENLABS_SECRET still works for the secret value
X_ELEVENLABS_SECRET_PLUMBINGPRO=
# X_ELEVENLABS_SECRET=
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: cache Google Sheet reads (seconds)
# SHEET_DATA_CACHE_TTL_SECONDS=0

# Optional: Twilio for POST /api/send-sms
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Optional: POST /api/escalate-human
# ESCALATION_WEBHOOK_URL=
# ESCALATION_WEBHOOK_SECRET=
# ESCALATION_TRANSFER_NUMBER=
